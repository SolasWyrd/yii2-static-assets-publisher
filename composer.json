{
  "name": "solas-wyrd/yii2-static-assets-publisher",
  "description": "Automatically discovers and publishes Yii2 AssetBundle resources for production builds",
  "keywords": [
    "yii2",
    "assets",
    "asset-bundle",
    "asset-publisher",
    "static-assets",
    "asset-manager",
    "docker",
    "build"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Artur Ushakov",
      "email": "ush.as@yandex.ru",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "nikic/php-parser": "^5.0",
    "yiisoft/yii2": "^2.0.49"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "SolasWyrd\\Yii2StaticAssets\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SolasWyrd\\Yii2StaticAssets\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "test-coverage": "@php vendor/bin/phpunit --coverage-clover build/coverage/clover.xml --coverage-text",
    "analyse": "@php vendor/bin/phpstan analyse --memory-limit=512M",
    "cs-check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs-fix": "@php vendor/bin/php-cs-fixer fix"
  },
  "support": {
    "issues": "https://github.com/SolasWyrd/yii2-static-assets-publisher/issues",
    "source": "https://github.com/SolasWyrd/yii2-static-assets-publisher"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ]
}

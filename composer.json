{
  "name": "solas-wyrd/yii2-static-assets-publisher",
  "description": "Discovers and publishes Yii2 AssetBundle classes during application build",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "nikic/php-parser": "^4.18 || ^5.0",
    "yiisoft/yii2": "^2.0.49"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "SolasWyrd\\Yii2StaticAssets\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SolasWyrd\\Yii2StaticAssets\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse"
  },
  "config": {
    "sort-packages": true
  }
}
